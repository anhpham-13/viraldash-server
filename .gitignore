# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
backend/dist/
frontend/.next/
frontend/out/

# ── Environment secrets ───────────────────────────────────────────────────────
.env
.env.local
.env.production

# ── Scraped data outputs (youtube pipeline) ───────────────────────────────────
# Use ** (not trailing /) so the .gitkeep exceptions below can pierce through.
data/youtube/**
!data/youtube/.gitkeep

# ── Scraped data outputs (tiktok pipeline) ────────────────────────────────────
data/tiktok/**
!data/tiktok/.gitkeep

# ── Scraped data outputs (instagram pipeline) ────────────────────────────────────
data/instagram/**
!data/instagram/.gitkeep

# ── Dedup seen-index state (binary shard files) ───────────────────────────────
data/seen_index_ssr/**
!data/seen_index_ssr/.gitkeep

# ── Playwright browser profiles created by workers ───────────────────────────
data/user_data_worker_*/
user_data_ig_worker_*/
data/user_data_ig_debug/

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log

# Third-party extensions
crawler/extensions/
