# ══════════════════════════════════════════════════════════════════════════════
#  ViralScope — environment variables template
#  Copy this file to .env and fill in every value before running.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════


# ── Runtime ───────────────────────────────────────────────────────────────────

NODE_ENV=development


# ── MongoDB (primary store) ───────────────────────────────────────────────────

# Full connection string, including credentials if any.
MONGODB_URI=mongodb://localhost:27017

# Database name inside the MongoDB instance.
MONGODB_DB=viralscope


# ── Backend API server ────────────────────────────────────────────────────────

PORT=4000

# Comma-separated frontend origins allowed by CORS (localhost:3000/3001 are always allowed).
ALLOWED_ORIGINS=

# Absolute or relative path to the audit JSONL directory.
# Default when unset: ../data  (sibling data/ dir from backend/).
DATA_DIR=


# ══════════════════════════════════════════════════════════════════════════════
#  CRAWLER — Business Logic Tuning
#  These control timing and thresholds. Commit the values you settle on so
#  the team can review changes in PRs.
# ══════════════════════════════════════════════════════════════════════════════


# ── Discovery Loop (Loop 1) ───────────────────────────────────────────────────
# Runs on-demand or via cron to find new viral videos each day.

# A video must have been published within this many hours to be considered.
# Default: 48  (covers today + yesterday to catch overnight virals)
DISCOVERY_MAX_AGE_HOURS=48

# Minimum viral_score (0–100) to write a video into the viral list.
# Default: 90
VIRAL_SCORE_THRESHOLD=90


# ── Refresh Loop (Loop 2) ─────────────────────────────────────────────────────
# Fetches fresh stats for the viral list to track velocity & acceleration.
#
# Key relationship:
#   expected snapshots per video ≈ REFRESH_MAX_AGE_HOURS / REFRESH_INTERVAL_HOURS
#
# Examples:
#   8h interval × 6 = 48h  →  ~6 snapshots  ✅ (default)
#   6h interval × 8 = 48h  →  ~8 snapshots  ✅ (more granular)
#   12h interval × 4 = 48h →  ~4 snapshots  ✅ (lighter load)

# How many hours between each refresh run.
# Default: 8
REFRESH_INTERVAL_HOURS=8

# Only refresh videos published within this many hours (their "tracking window").
# After this, a video is considered "cold" and dropped from the refresh queue.
# Default: 48
REFRESH_MAX_AGE_HOURS=48

# Skip refresh for videos whose viral_score has dropped below this threshold.
# Saves requests on videos that are clearly fading.
# Default: 50
REFRESH_MIN_SCORE=50


# ── Concurrency & Rate Limiting ───────────────────────────────────────────────

# Parallel Playwright browser instances (higher = faster but more RAM & risk of bans).
# Default: 3
BROWSER_CONCURRENCY=3

# Parallel non-browser API requests (YouTube Data API, RapidAPI, etc.).
# Default: 5
API_CONCURRENCY=5

# Random human-like delay range between individual requests (milliseconds).
# Default: 1000–3000ms
HUMAN_DELAY_MIN_MS=1000
HUMAN_DELAY_MAX_MS=3000

# Fixed pause between API batch calls (e.g. YouTube Data API batches of 50).
# Default: 1200ms
BATCH_DELAY_MS=1200


# ── Viral Score Gate Thresholds ───────────────────────────────────────────────
# Pre-filter before running the full score formula. Rarely needs changing.

SCORE_MIN_VIEWS=2000
SCORE_MIN_VPH=5000
SCORE_MIN_LIKES=100
# Like rate as a decimal: 0.01 = 1%
SCORE_MIN_LR=0.01


# ══════════════════════════════════════════════════════════════════════════════
#  PLATFORM API KEYS
# ══════════════════════════════════════════════════════════════════════════════


# ── YouTube ───────────────────────────────────────────────────────────────────

YOUTUBE_DATA_API_KEY=
# Optional rotation keys
API_V3_1=
API_V3_2=


# ── TikTok (RapidAPI) ────────────────────────────────────────────────────────

RAPID_API_HOST=
# Comma-separated list for round-robin key rotation
RAPID_API_KEYS=

# Region and language targeting
CRAWL_REGIONS=US
CRAWL_LANG=en

# Set to "true" to skip Playwright/Google scraping and use only RapidAPI
ONLY_RAPID=false


# ── Instagram ─────────────────────────────────────────────────────────────────

# Comma-separated Serper API keys
SERPER_API_KEYS=
SERPER_DELAY_MS=1000
SERPER_NUM=10


# ── Browser (Playwright) ──────────────────────────────────────────────────────

# WebSocket URL for a remote browser service (e.g. Browserless). Leave blank for local Chromium.
CLOAK_BROWSER_WS=
CLOAK_BROWSER_PORT=9222

# Set to "false" to open a visible browser window (useful for debugging).
HEADLESS=true
