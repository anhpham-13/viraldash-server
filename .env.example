# ══════════════════════════════════════════════════════════════════════════════
#  viraldash-server — environment variables template
#  Copy this file to .env and fill in every value before running.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════


# ── Backend API server ────────────────────────────────────────────────────────

# TCP port the Hono server binds to.
PORT=4000

# Comma-separated list of frontend origins allowed by CORS.
# The server always permits http://localhost:3000 and :3001 in addition.
# Example: https://app.viraldash.io,https://staging.viraldash.io
ALLOWED_ORIGINS=

# Absolute path (or path relative to backend/) to the shared data directory.
# Default when unset: ../data  (i.e. the sibling data/ dir from backend/).
DATA_DIR=


# ── Shared crawler settings ───────────────────────────────────────────────────

NODE_ENV=development

# How many days back a video must be published to be considered "recent".
MAX_VIDEO_AGE_DAYS=1

# Minimum viral score (0-100) a video must reach to be written to viral_vids.
VIRAL_SCORE_THRESHOLD=90

# Maximum number of concurrent enrichment requests.
ENRICHER_CONCURRENCY=5

# Set to "true" to run the full pipeline automatically on worker start.
RUN_PIPELINE=true


# ── YouTube crawler ───────────────────────────────────────────────────────────

# Primary YouTube Data API v3 key.
YOUTUBE_DATA_API_KEY=

# Optional additional rotation keys (API_V3_1 and API_V3_2 are aliases).
API_V3_1=
API_V3_2=


# ── TikTok crawler ────────────────────────────────────────────────────────────

# RapidAPI host for the TikTok data endpoint.
RAPID_API_HOST=

# Comma-separated list of RapidAPI keys for round-robin key rotation.
RAPID_API_KEYS=

# Comma-separated ISO 3166-1 alpha-2 region codes to crawl.
CRAWL_REGIONS=US

# BCP-47 language tag used to filter content locale.
CRAWL_LANG=en

# Maximum number of concurrent Playwright browser instances.
MAX_BROWSER_CONCURRENCY=3

# Comma-separated Serper API keys for Google search scraping.
SERPER_API_KEYS=

# Delay (ms) injected between Serper requests to avoid rate limits.
SERPER_DELAY_MS=1000

# Number of Serper result pages to fetch per query.
SERPER_NUM=10

# Set to "true" to skip Playwright/Google scraping and use only the RapidAPI path.
ONLY_RAPID=false

# WebSocket URL for a remote browser-as-a-service endpoint (e.g. Browserless).
# Leave blank to launch a local Chromium instance instead.
CLOAK_BROWSER_WS=

# Local debug port for the Chrome DevTools Protocol when running headfully.
CLOAK_BROWSER_PORT=9222

# Set to "false" to open a visible browser window (useful during local debugging).
HEADLESS=true
