# Server
PORT=4000
NODE_ENV=development

# Absolute or relative path to the data directory (relative to cwd = backend/)
# Default when unset: ../data  (the sibling data/ folder in the monorepo)
DATA_DIR=../data

# CORS – comma-separated list of allowed frontend origins
# In production set this to your deployed frontend URL, e.g.:
#   ALLOWED_ORIGINS=https://your-app.vercel.app
# In development the value below is used; localhost:3000 is always added automatically.
ALLOWED_ORIGINS=http://localhost:3000
